                <!-- Row 1: Market Research -->
                <rect x="400" y="20" width="300" height="60" class="node-rect" fill="url(#grad-gold)" stroke="#d4a843"/>
                <text x="550" y="42" class="node-text-lg">MARKET RESEARCH</text>
                <text x="550" y="62" class="node-text-sm">TAM · SAM · SOM · Trends</text>

                <line x1="550" y1="80" x2="550" y2="110" class="arrow-line" stroke="#d4a843"/>

