    <!-- ▬▬▬▬ 3. 30-60-90 TIMELINE ▬▬▬▬ -->
    <section class="section reveal" id="timeline">
        <div class="section-head">
            <span class="section-num">03</span>
            <h2>30-60-90 Day Leadership Plan</h2>
            <p>Three phases — Immersion, Re-Architecture, and Execution — for GTM leaders rebuilding or launching a function.</p>
        </div>

        <div class="diagram-wrap">
            <div class="diagram-title">Three-Phase GTM Leadership Timeline</div>
            <svg viewBox="0 0 1100 550" xmlns="http://www.w3.org/2000/svg">
                <!-- Main timeline axis -->
                <line x1="80" y1="200" x2="1020" y2="200" stroke="#d4a843" stroke-width="2" opacity="0.3"/>
