<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GTM Playbook — Visual Diagrams</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=DM+Mono:wght@300;400;500&family=Source+Serif+4:opsz,wght@8..60,300;8..60,400;8..60,600&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

        :root {
            --bg: #08080c;
            --surface: #10101a;
            --elevated: #18182a;
            --card: #1c1c30;
            --accent: #d4a843;
            --accent-dim: #a07c2e;
            --accent-glow: rgba(212,168,67,0.1);
            --accent-glow2: rgba(212,168,67,0.06);
            --text: #f0ece4;
            --text2: #b8b2a6;
            --muted: #5e5a52;
            --border: rgba(212,168,67,0.1);
            --border2: rgba(212,168,67,0.2);
            --blue: #5b9bd5;
            --green: #5cb87a;
            --red: #d45b5b;
            --purple: #9b7dd4;
            --teal: #4dbdbd;
        }

        html { scroll-behavior: smooth; }

        body {
            font-family: 'Source Serif 4', Georgia, serif;
            background: var(--bg);
            color: var(--text);
            line-height: 1.7;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background:
                radial-gradient(ellipse at 15% 20%, rgba(212,168,67,0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 85% 80%, rgba(91,155,213,0.03) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(155,125,212,0.02) 0%, transparent 60%);
            pointer-events: none;
        }

        ::selection { background: var(--accent); color: var(--bg); }

        /* ─── NAV ─── */
        .topnav {
            position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
            background: rgba(8,8,12,0.92);
            backdrop-filter: blur(24px);
            border-bottom: 1px solid var(--border);
        }
        .topnav-inner {
            max-width: 1400px; margin: 0 auto; padding: 0 2rem;
            display: flex; align-items: center; justify-content: space-between; height: 60px;
        }
        .topnav-brand {
            font-family: 'Playfair Display', serif;
            font-weight: 900; font-size: 1rem; color: var(--accent);
        }
        .topnav-brand span { color: var(--muted); font-weight: 400; font-size: 0.8rem; margin-left: 0.4rem; }
        .topnav-links {
            display: flex; gap: 0.2rem; list-style: none;
        }
        .topnav-links a {
            font-family: 'DM Mono', monospace; font-size: 0.65rem;
            text-transform: uppercase; letter-spacing: 0.08em;
            color: var(--muted); padding: 0.4rem 0.65rem; border-radius: 4px;
            text-decoration: none; transition: all 0.2s;
            white-space: nowrap;
        }
        .topnav-links a:hover { color: var(--accent); background: var(--accent-glow); }

        /* ─── HERO ─── */
        .hero {
            min-height: 70vh; display: flex; align-items: center; justify-content: center;
            padding: 8rem 2rem 4rem; text-align: center; position: relative;
        }
        .hero-label {
            font-family: 'DM Mono', monospace; font-size: 0.65rem;
            text-transform: uppercase; letter-spacing: 0.2em; color: var(--accent);
            margin-bottom: 1.5rem;
            opacity: 0; animation: fadeUp 0.6s ease 0.2s forwards;
        }
        .hero h1 {
            font-family: 'Playfair Display', serif; font-weight: 900;
            font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.1; margin-bottom: 1rem;
            opacity: 0; animation: fadeUp 0.8s ease 0.4s forwards;
        }
        .hero h1 em { font-style: italic; color: var(--accent); }
        .hero p {
            font-size: 1.05rem; color: var(--text2); max-width: 650px; margin: 0 auto;
            opacity: 0; animation: fadeUp 0.8s ease 0.6s forwards;
        }

        @keyframes fadeUp {
            from { opacity: 0; transform: translateY(24px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ─── MAIN ─── */
        .main { max-width: 1200px; margin: 0 auto; padding: 0 2rem 6rem; }

        /* ─── SECTION ─── */
        .section { margin-bottom: 5rem; }
        .section-head {
            position: relative; padding: 3rem 0 2rem; margin-bottom: 2rem;
            border-bottom: 1px solid var(--border);
        }
        .section-num {
            font-family: 'Playfair Display', serif; font-size: 4rem; font-weight: 900;
            color: var(--accent); opacity: 0.1; position: absolute; top: 0; left: 0; line-height: 1;
        }
        .section-head h2 {
            font-family: 'Playfair Display', serif; font-size: 1.9rem; font-weight: 700;
            position: relative; z-index: 1;
        }
        .section-head p { color: var(--text2); margin-top: 0.5rem; max-width: 700px; font-size: 0.95rem; }

        /* ─── DIAGRAM CONTAINER ─── */
        .diagram-wrap {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2.5rem;
            margin: 2rem 0;
            overflow-x: auto;
            position: relative;
        }
        .diagram-wrap::before {
            content: '';
            position: absolute; inset: 0; border-radius: 16px;
            background: radial-gradient(ellipse at 50% 0%, var(--accent-glow2), transparent 60%);
            pointer-events: none;
        }
        .diagram-wrap svg {
            display: block; margin: 0 auto;
            max-width: 100%; height: auto;
        }
        .diagram-title {
            font-family: 'DM Mono', monospace; font-size: 0.65rem;
            text-transform: uppercase; letter-spacing: 0.15em; color: var(--muted);
            margin-bottom: 1.5rem; text-align: center;
        }

        /* ─── SVG STYLES ─── */
        .node-rect {
            rx: 10; ry: 10;
            stroke-width: 1.5;
            transition: all 0.3s ease;
        }
        .node-rect:hover { filter: brightness(1.2); }
        .node-text {
            font-family: 'DM Mono', monospace; font-size: 11px;
            fill: var(--text); text-anchor: middle; dominant-baseline: central;
            pointer-events: none;
        }
        .node-text-sm {
            font-family: 'DM Mono', monospace; font-size: 9px;
            fill: var(--text2); text-anchor: middle; dominant-baseline: central;
            pointer-events: none;
        }
        .node-text-lg {
            font-family: 'Playfair Display', serif; font-size: 13px; font-weight: 700;
            fill: var(--text); text-anchor: middle; dominant-baseline: central;
            pointer-events: none;
        }
        .arrow-line {
            stroke-width: 1.5; fill: none;
            marker-end: url(#arrowhead);
        }
        .arrow-dash {
            stroke-width: 1; fill: none; stroke-dasharray: 5,4;
            marker-end: url(#arrowhead-sm);
        }
        .label-text {
            font-family: 'DM Mono', monospace; font-size: 9px;
            fill: var(--muted); text-anchor: middle;
        }

        /* ─── REVEAL ─── */
        .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.6s, transform 0.6s; }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        /* ─── RESPONSIVE ─── */
        @media (max-width: 768px) {
            .topnav-links { display: none; }
            .diagram-wrap { padding: 1.5rem 1rem; }
            .section-head h2 { font-size: 1.5rem; }
        }
    </style>
</head>
<body>

<!-- ═══ NAV ═══ -->
<header class="topnav">
    <div class="topnav-inner">
        <div class="topnav-brand">GTM DIAGRAMS <span>Visual Playbook</span></div>
        <ul class="topnav-links">
            <li><a href="#overview">Overview</a></li>
            <li><a href="#five-pillars">Pillars</a></li>
            <li><a href="#timeline">Timeline</a></li>
            <li><a href="#phases">12 Phases</a></li>
            <li><a href="#decision">Decision</a></li>
            <li><a href="#funnel">Funnel</a></li>
            <li><a href="#email-flow">Email Flow</a></li>
            <li><a href="#metrics">Metrics</a></li>
            <li><a href="#beachhead">Beachhead</a></li>
        </ul>
    </div>
</header>

<!-- ═══ HERO ═══ -->
<section class="hero">
    <div>
        <div class="hero-label">Visual Intelligence</div>
        <h1>GTM Playbook<br><em>Diagrams</em></h1>
        <p>Flow diagrams, decision trees, timelines, and strategic frameworks to visualize every layer of the Go-to-Market methodology.</p>
