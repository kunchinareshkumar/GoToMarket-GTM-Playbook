                    </linearGradient>
                    <linearGradient id="grad-green" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#5cb87a" stop-opacity="0.2"/>
                        <stop offset="100%" stop-color="#3a9a5a" stop-opacity="0.08"/>
                    </linearGradient>
                    <linearGradient id="grad-purple" x1="0" y1="0" x2="1" y2="1">
                        <stop offset="0%" stop-color="#9b7dd4" stop-opacity="0.2"/>
